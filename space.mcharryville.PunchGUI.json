{
    "app-id": "space.mcharryville.PunchGUI",
    "runtime": "org.gnome.Platform",
    "runtime-version": "47",
    "sdk": "org.gnome.Sdk",
    "command": "punch_gui.py",
    "finish-args": [
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--device=dri",
        "--share=network"
    ],
    "modules": [
        {
            "name": "punch-gui",
            "buildsystem": "simple",
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ],
            "build-commands": [
                "install -D punch_gui.py /app/bin/punch_gui.py",
                "install -D about.py /app/bin/about.py",
                "install -Dm644 space.mcharryville.PunchGUI.desktop /app/share/applications/space.mcharryville.PunchGUI.desktop",
                "install -Dm644 space.mcharryville.PunchGUI.svg /app/share/icons/hicolor/scalable/apps/space.mcharryville.PunchGUI.svg"
            ]
        }
    ]
}
